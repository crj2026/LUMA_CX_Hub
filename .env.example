# ─────────────────────────────────────────────────────────────────────
# [BRAND_NAME] CX Hub — environment variables
# Copy this file to .env.local and fill in real values. See BRAND_SETUP.md.
# ─────────────────────────────────────────────────────────────────────

# ── Auth (required) — from your Clerk dashboard → API Keys ──
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_or_live_xxx
CLERK_SECRET_KEY=sk_test_or_live_xxx

# ── Owner (recommended) — this email gets the Owner role on sign-in ──
OWNER_EMAIL=[owner@brand.com]

# ── AI — Ask AI chat + AI surfaces (required) — console.anthropic.com ──
ANTHROPIC_API_KEY=sk-ant-xxx

# ── Database (required if using the DB-backed features / migrations) ──
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Shopify (optional) — order/refund data ──
SHOPIFY_STORE_URL=[brand].myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxx
SHOPIFY_API_VERSION=2024-04

# ── Gorgias (optional) — ticket data ──
GORGIAS_DOMAIN=[GORGIAS_SUBDOMAIN]
GORGIAS_USERNAME=ops@[brand].com
GORGIAS_API_KEY=xxx
GORGIAS_ACCOUNT_ID=xxx
# If the Gorgias account is shared across brands, set the tag that marks
# this brand's tickets (used by lib/insights.js):
# BRAND_TICKET_TAG=[BRAND_TAG]

# ── Skio (optional) — subscription data ──
SKIO_API_URL=https://graphql.skio.com/v1/graphql
SKIO_API_TOKEN=xxx
SKIO_SITE_ID=xxx

# ── Loop Returns (optional) — returns/refund data ──
LOOP_API_BASE=https://api.loopreturns.com/api/v1
LOOP_API_KEY=xxx

# ── App URL (optional) — used for Clerk invitation redirects ──
APP_URL=[HUB_URL]

# ── Cron bypass (optional) — for scheduled cache warmers ──
CRON_SECRET=any-long-random-string
